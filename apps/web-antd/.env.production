VITE_BASE=/

# 接口地址
VITE_GLOB_API_URL=https://api.junlee.top

# 是否开启压缩，可以设置为 none, brotli, gzip
VITE_COMPRESS=none

# 是否开启 PWA
VITE_PWA=false

# vue-router 的模式：history 不带 #，需要服务器把前端路由回退到 index.html
VITE_ROUTER_HISTORY=history

# 是否注入全局loading
VITE_INJECT_APP_LOADING=true

# 打包后是否生成dist.zip
VITE_ARCHIVER=true
